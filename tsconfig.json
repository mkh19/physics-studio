{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],

    "strict": true,

    "skipLibCheck": true,

    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,

    "isolatedModules": true,

    "noEmit": true,

    "resolveJsonModule": true
  },

  "include": [
    "src",
    "demo"
  ]
}